rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid} (Firebase Auth UID)
    // Fields:
    //   - displayName: string (required, 1-80 chars)
    //   - email: string (optional)
    //   - phoneNumber: string (optional)
    //   - birthdate: string|null (optional, yyyy-mm-dd)
    //   - focusAreas: list<string> (optional)
    //   - baselineMood: number|null (optional, 1-5)
    //   - experienceLevel: string|null (optional: new|some|devoted)
    //   - primaryIntention: string (optional)
    //   - createdAt: timestamp (required on create)
    //   - updatedAt: timestamp (required)
    //
    // Collection: users/{uid}/checkins/{checkinId}
    // Fields:
    //   - kind: string (morning|evening)
    //   - checkinDate: string (yyyy-mm-dd)
    //   - scores: map (optional numeric fields)
    //   - notes: map (optional string fields)
    //   - createdAt: timestamp
    //
    // Collection: users/{uid}/journalEntries/{entryId}
    // Fields:
    //   - body: string
    //   - modality: string (text|voice)
    //   - themes: list<string>
    //   - createdAt: timestamp
    //
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'updatedAt'])
        && data.displayName is string
        && data.displayName.size() > 0
        && data.displayName.size() <= 80
        && (!('email' in data) || data.email is string)
        && (!('phoneNumber' in data) || data.phoneNumber is string)
        && (!('focusAreas' in data) || data.focusAreas is list)
        && (!('baselineMood' in data) || data.baselineMood == null
            || (data.baselineMood is number && data.baselineMood >= 1 && data.baselineMood <= 5))
        && (!('experienceLevel' in data) || data.experienceLevel == null
            || data.experienceLevel in ['new', 'some', 'devoted'])
        && (!('primaryIntention' in data) || data.primaryIntention is string);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && isValidUser(request.resource.data)
        && request.resource.data.keys().hasAll(['createdAt']);
      allow update: if isOwner(userId)
        && isValidUser(request.resource.data);
      allow delete: if isOwner(userId);

      match /checkins/{checkinId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      match /journalEntries/{entryId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      match /conversations/{conversationId} {
        allow read, create, update, delete: if isOwner(userId);

        match /messages/{messageId} {
          allow read, create, update, delete: if isOwner(userId);
        }
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
