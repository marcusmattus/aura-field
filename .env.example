# Expo / app
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# EAS project link (from `npx eas init` / expo.dev)
EAS_PROJECT_ID=
EXPO_OWNER=
EXPO_TOKEN=

# Optional native ID overrides
BILT_APP_VERSION=1.0.0
BILT_IOS_BUNDLE_ID=com.aurafield.app
BILT_ANDROID_PACKAGE=com.aurafield.app

# Required for non-interactive iOS EAS Submit (App Store Connect → App Information → Apple ID)
BILT_APP_STORE_APP_ID=
# Optional Apple team / account overrides
BILT_APPLE_TEAM_ID=
EXPO_APPLE_ID=mattusmarcus@gmail.com
# Prefer App Store Connect API key via `eas credentials` over app-specific password
# EXPO_APPLE_APP_SPECIFIC_PASSWORD=
